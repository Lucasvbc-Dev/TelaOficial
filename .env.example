#!/bin/bash
# ===============================================
# 🔐 ARQUIVO DE CONFIGURAÇÃO DE AMBIENTE
# ===============================================
# 
# INSTRUÇÕES:
# 1. Copie este arquivo para .env
# 2. Preencha com seus valores reais
# 3. NÃO COMMITE O ARQUIVO .env (está em .gitignore)
#
# ===============================================

# ==========================================
# 🌍 SPRING BOOT
# ==========================================
SPRING_PROFILES_ACTIVE=dev
PORT=8080
APP_TIMEZONE=America/Sao_Paulo

# ==========================================
# 🔥 FIREBASE
# ==========================================
# ID do seu projeto Firebase
FIREBASE_PROJECT_ID=seu-projeto-firebase-123abc
# Caminho para o arquivo de credenciais JSON
# Pode ser classpath:firebase-service-account.json ou /path/absoluto
FIREBASE_CREDENTIALS_PATH=classpath:firebase-service-account.json
FIREBASE_ENABLED=true

# ==========================================
# 💳 MERCADO PAGO - TOKENS DE TESTE
# ==========================================
# Para teste: https://www.mercadopago.com.br/developers
# Copie de: "Tus credenciales" → "Access Token de TEST"
# 
# IMPORTANTE: Comece com "TEST-" para testes
MERCADOPAGO_ACCESS_TOKEN=TEST-1234567890abcdefghijklmnopqrs
# Secret para validar webhook (se houver)
MERCADOPAGO_WEBHOOK_SECRET=sua_webhook_secret_aqui
# URL base (deixe como está)
MERCADOPAGO_BASE_URL=https://api.mercadopago.com

# ==========================================
# 💳 MERCADO PAGO - TOKENS DE PRODUÇÃO
# ==========================================
# NUNCA COMMITE TOKENS DE PRODUÇÃO!
# Use apenas em ambiente seguro (CI/CD secrets, cloud provider secrets)
#
# Depois de testar, troque TEST- por PROD-:
# MERCADOPAGO_ACCESS_TOKEN=PROD-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# MERCADOPAGO_PUBLIC_KEY=PROD-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ==========================================
# 🔐 JWT AUTHENTICATION
# ==========================================
# Gere uma chave segura com:
# openssl rand -base64 32
#
# TESTE (não seguro, apenas para desenvolvimento):
AUTH_JWT_SECRET=dev-secret-change-this-key-with-at-least-32-characters
# PRODUÇÃO (exigido):
# AUTH_JWT_SECRET=seu-chave-aleatoria-segura-de-32-caracteres-aqui

AUTH_JWT_EXPIRATION_MINUTES=1440

# Lista de emails admin (separados por vírgula)
AUTH_ADMIN_EMAILS=admin@tela.com,lucas@tela.com

# ==========================================
# ✅ CORS
# ==========================================
# Origens permitidas (separadas por vírgula)
# Em desenvolvimento:
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:4200
# Em produção:
# APP_CORS_ALLOWED_ORIGINS=https://seudominio.com,https://www.seudominio.com

# ==========================================
# 📋 ERROR HANDLING
# ==========================================
# Em desenvolvimento (verbose):
SERVER_ERROR_INCLUDE_MESSAGE=always
SERVER_ERROR_INCLUDE_BINDING_ERRORS=true
# Em produção (seguro):
# SERVER_ERROR_INCLUDE_MESSAGE=never
# SERVER_ERROR_INCLUDE_BINDING_ERRORS=false

# ==========================================
# 🎨 FRONTEND (Vite)
# ==========================================
VITE_API_URL=http://localhost:8080
VITE_FIREBASE_PROJECT=seu-projeto-firebase-123abc
